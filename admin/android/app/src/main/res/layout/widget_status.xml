<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/widget_status_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="horizontal"
    android:gravity="center_vertical"
    android:padding="12dp"
    android:background="@drawable/widget_bg_rounded_status"
    android:clickable="true"
    android:focusable="true">

    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:orientation="vertical">

        <TextView
            android:id="@+id/widget_status_title"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="RagChat"
            android:textColor="#FFFFFF"
            android:textSize="16sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/widget_status_subtitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="2dp"
            android:text="Tap to open dashboard"
            android:textColor="#B3FFFFFF"
            android:textSize="11sp" />

    </LinearLayout>

    <ImageView
        android:id="@+id/widget_status_chat_btn"
        android:layout_width="36dp"
        android:layout_height="36dp"
        android:layout_marginEnd="8dp"
        android:padding="6dp"
        android:background="@drawable/widget_icon_bg"
        android:src="@android:drawable/sym_action_chat"
        android:contentDescription="Chat"
        android:tint="#FFFFFF" />

    <ImageView
        android:id="@+id/widget_status_upload_btn"
        android:layout_width="36dp"
        android:layout_height="36dp"
        android:padding="6dp"
        android:background="@drawable/widget_icon_bg"
        android:src="@android:drawable/ic_menu_upload"
        android:contentDescription="Upload"
        android:tint="#FFFFFF" />

</LinearLayout>
